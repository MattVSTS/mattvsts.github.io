<article class='c-post-card'>
  <div class='c-post-card__meta'>
    <time class='c-post-card__date'>{{ post.date | date: '%b %d, %Y' | upcase }}</time>
    {% if post.tags.size > 0 %}
      <div class='c-post-card__tags'>
        {% for tag in post.tags limit:3 %}
          <span class='c-post-card__tag'>{{ tag }}</span>
        {% endfor %}
      </div>
    {% endif %}
  </div>
  <h3 class='c-post-card__title'>
    <a href='{{ post.url | prepend: site.baseurl }}'>{{ post.title }}</a>
  </h3>
  <p class='c-post-card__excerpt'>{{ post.content | strip_html | truncatewords: 30 }}</p>
  <a href='{{ post.url | prepend: site.baseurl }}' class='c-post-card__read-more'>Read more &rarr;</a>
</article>
